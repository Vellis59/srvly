{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/Vellis59/srvly/master/recipes/recipe-schema.json",
  "title": "srvly Recipe v2",
  "description": "Schema de validation des recettes d'application pour srvly",
  "type": "object",
  "required": ["metadata", "prerequisites", "install", "healthcheck"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["name", "description", "category", "tags"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "description": { "type": "string", "minLength": 10, "maxLength": 2000 },
        "category": {
          "type": "string",
          "enum": [
            "analytics", "automation", "backup", "cms", "communication",
            "community", "crm", "database", "development", "dns", "documents",
            "email", "entertainment", "finance", "gaming", "iot", "learning",
            "marketing", "media", "monitoring", "networking", "notes", "office",
            "password", "personal", "privacy", "project-management", "proxy",
            "recruitment", "security", "storage", "system", "web-server"
          ]
        },
        "tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "version": { "type": "string" },
        "homepage": { "type": "string" },
        "icon": { "type": "string" },
        "license": { "type": "string" },
        "verified": { "type": "boolean" },
        "verified_at": { "type": "string", "format": "date-time" },
        "verified_by": { "type": "string" }
      }
    },
    "prerequisites": {
      "type": "object",
      "required": ["databases", "ports"],
      "properties": {
        "databases": {
          "type": "object",
          "properties": {
            "postgres": { "type": "boolean" },
            "mysql": { "type": "boolean" },
            "redis": { "type": "boolean" },
            "mongodb": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "ports": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "minItems": 1
        },
        "resources": {
          "type": "object",
          "properties": {
            "ram": { "type": "integer", "minimum": 64 },
            "disk": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "install": {
      "type": "object",
      "required": ["docker"],
      "properties": {
        "docker": {
          "type": "object",
          "required": ["image", "name", "port"],
          "properties": {
            "image": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "port": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
            "volumes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "env": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["key"],
                "properties": {
                  "key": { "type": "string" },
                  "value": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "healthcheck": {
      "type": "object",
      "required": ["type", "port", "timeout"],
      "properties": {
        "type": { "type": "string", "enum": ["http", "tcp", "script"] },
        "port": { "type": "integer" },
        "path": { "type": "string" },
        "expected": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "timeout": { "type": "integer", "minimum": 5, "maximum": 120 }
      }
    },
    "params": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "title": { "type": "string" },
          "default": {},
          "description": { "type": "string" }
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string", "maxLength": 5000 }
  }
}
