# ─── srvly — Environment Variables ───
# Copy this file to .env and fill in your values.

# Database
DATABASE_URL=postgres://srvly:YOUR_PASSWORD@postgres:5432/srvly
POSTGRES_PASSWORD=YOUR_PASSWORD

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
NEXTAUTH_URL=https://YOUR_DOMAIN
NEXT_PUBLIC_BASE_URL=https://YOUR_DOMAIN
NEXT_PUBLIC_APP_URL=https://YOUR_DOMAIN

# GitHub OAuth (https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (https://console.cloud.google.com/auth/clients)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (transactional emails — https://resend.com)
RESEND_API_KEY=
RESEND_FROM=welcome@mg.srvly.app

# SSH
SSH_KEY_PATH=/app/ssh_keys
