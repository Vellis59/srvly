FROM golang:1.22-alpine AS build
WORKDIR /app
COPY go.mod ./
RUN go mod tidy
COPY . .
RUN CGO_ENABLED=0 go build -o /tunnel-server ./cmd/tunnel-server

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=build /tunnel-server /usr/local/bin/tunnel-server
EXPOSE 8080
CMD ["tunnel-server"]
